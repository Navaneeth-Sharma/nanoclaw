DISCORD_BOT_TOKEN=
# OpenCode Go API key — required for models via opencode-go provider
OPENCODE_GO_API_KEY=your-opencode-go-api-key-here
# Model to use. Options: opencode-go/glm-5, opencode-go/kimi-k2.5, opencode-go/minimax-m2.5
OPENCODE_MODEL=opencode-go/glm-5

# GitHub integration — lets the container agent commit, push, and open PRs
# Create a token at https://github.com/settings/tokens with repo + workflow scopes
GITHUB_TOKEN=
GITHUB_USER=your-github-username
GITHUB_EMAIL=your-github-email@example.com

# Assistant name (shown in @mentions and conversation archives)
ASSISTANT_NAME=Andy

# Set to true if the assistant has its own dedicated phone number
ASSISTANT_HAS_OWN_NUMBER=false
